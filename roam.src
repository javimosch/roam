// roam — dispatch an autonomous agent that roams to a remote box and works while
// you're away. ONE static binary, controller + worker in the same executable.
//
// Slice 1a (this file): the SKELETON — no LLM yet. Proves the machine end to end,
// fully locally: a detached worker loop that ticks trivial work into a SQLite
// journal, drains a steering mailbox at each checkpoint, and is inspectable /
// steerable / stoppable from separate control commands. The ssh `send`-to-remote
// layer (slice 1b) drops on top of this unchanged: control ops just run over ssh
// against the same journal.
//
// Storage (per job): ~/.roam/<jobid>.db, SQLite in WAL mode so the worker (writer)
// and status/attach (readers) can hold it at once.
//   state   (k, v)                 — status | goal | every | tick | host | started
//   journal (id, ts, kind, msg)    — append-only, the audit trail you'll `pull`
//   mailbox (id, ts, consumed, cmd, arg) — steering, drained at safe checkpoints
//
// Agent-first CLI contract: stdout = JSON answer, stderr = errors, semantic exits.

type KV struct { v string }
type JRow struct { id int  ts int  kind string  msg string }
type MRow struct { id int  cmd string  arg string }

// ---- small helpers ------------------------------------------------------------

// jstr JSON-encodes a string (no json-encode builtin yet): quote + escape.
func jstr(s) (out) {
    b := bytes(s)
    r := "\""
    i := 0
    for i < len(b) {
        c := byte_at(b, i)
        if c == 34 { r = r + "\\\"" } else {
        if c == 92 { r = r + "\\\\" } else {
        if c == 10 { r = r + "\\n" } else {
        if c == 9 { r = r + "\\t" } else {
        if c == 13 { r = r + "\\r" } else {
            r = r + substr(s, i, i + 1)
        }}}}}
        i = i + 1
    }
    out = r + "\""
}

func atoi(s) (n) { n = parse(s, 0) }

func flag(a, name, def) (v) {
    v = def
    i := 0
    for i < len(a) {
        if a[i] == name && i + 1 < len(a) { v = a[i + 1] }
        i = i + 1
    }
}
func has_flag(a, name) (b) {
    b = false
    i := 0
    for i < len(a) { if a[i] == name { b = true }  i = i + 1 }
}

func roam_home() (p) {
    p = env("HOME") + "/.roam"
    mkdir(p)
}
func db_path(jobid) (p) { p = roam_home() + "/" + jobid + ".db" }

func write_last(jobid) { write_file(roam_home() + "/last", jobid) }

// is_terminal: has the job reached an end state? (attach stops streaming on these.)
func is_terminal(st) (b) {
    b = 0
    if st == "stopped" || st == "done" || st == "halted" || st == "error" { b = 1 }
}

// flag_rest returns every arg after `name`, space-joined (for --goal, which is
// multi-word and must therefore be the last flag on the command line).
func flag_rest(a, name) (v) {
    v = ""
    i := 0
    for i < len(a) {
        if a[i] == name {
            parts := []string{}
            j := i + 1
            for j < len(a) { parts = append(parts, a[j])  j = j + 1 }
            v = join(parts, " ")
            return v
        }
        i = i + 1
    }
}

// ---- storage ------------------------------------------------------------------

func open_db(path) (db) {
    db = sqlite_open(path)
    sqlite_exec(db, "PRAGMA journal_mode=WAL")
    sqlite_exec(db, "PRAGMA busy_timeout=5000")
}
func ensure_schema(db) {
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS state (k TEXT PRIMARY KEY, v TEXT)")
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS journal (id INTEGER PRIMARY KEY AUTOINCREMENT, ts INTEGER, kind TEXT, msg TEXT)")
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS mailbox (id INTEGER PRIMARY KEY AUTOINCREMENT, ts INTEGER, consumed INTEGER DEFAULT 0, cmd TEXT, arg TEXT)")
}
func state_set(db, k, v) {
    sqlite_exec(db, "INSERT OR REPLACE INTO state (k, v) VALUES (?, ?)", []string{k, v})
}
func state_get(db, k) (v) {
    v = ""
    rows := sqlite_query(db, "SELECT v FROM state WHERE k = ?", []string{k})
    kvs := parse(rows, []KV{})
    if len(kvs) > 0 { v = kvs[0].v }
}
func journal(db, kind, msg) {
    sqlite_exec(db, "INSERT INTO journal (ts, kind, msg) VALUES (?, ?, ?)", []string{str(now()), kind, msg})
}
func mailbox_put(db, cmd, arg) {
    sqlite_exec(db, "INSERT INTO mailbox (ts, consumed, cmd, arg) VALUES (?, 0, ?, ?)", []string{str(now()), cmd, arg})
}

// init_job creates a fresh job's DB + initial state, reading all config from the CLI args
// `a` (via the cfg_* helpers) so it's one code path locally and on the remote (_boot) —
// and adding a new flag is a one-liner, not a growing positional signature.
func init_job(jobid, goal, every, host, a) {
    db := open_db(db_path(jobid))
    ensure_schema(db)
    state_set(db, "status", "running")
    state_set(db, "goal", goal)
    state_set(db, "every", every)
    state_set(db, "host", host)
    state_set(db, "started", str(now()))
    state_set(db, "tick", "0")
    state_set(db, "iters", "0")
    state_set(db, "tokens", "0")
    state_set(db, "kind", cfg_kind(a))            // "agent" (LLM loop) | "tick" (skeleton demo)
    state_set(db, "provider", cfg_provider(a))    // "anthropic" | "openai" (OpenAI-compatible)
    state_set(db, "model", cfg_model(a))
    state_set(db, "maxiter", cfg_maxiter(a))
    state_set(db, "tokbudget", cfg_tokens(a))
    state_set(db, "allow_shell", cfg_shell(a))
    state_set(db, "confirm", cfg_confirm(a))      // "1" -> destructive shell cmds park for approval
    state_set(db, "maxdenials", cfg_maxdenials(a))// deny budget: N denials -> auto-halt
    state_set(db, "denials", "0")
    state_set(db, "verify", cfg_verify(a))        // "1" -> a `finish` is checked before it's accepted
    state_set(db, "maxverify", cfg_maxverify(a))  // verify budget: N failed verifies -> halt
    state_set(db, "vfails", "0")
    state_set(db, "pending", "")
    state_set(db, "api_base", cfg_apibase(a))
    state_set(db, "debri_perm", cfg_debri_perm(a))// --provider debri: devin permission-mode (auto|dangerous)
    state_set(db, "debri_stable", cfg_debri_stable(a))
    state_set(db, "api_key", get_key())           // job-local secret (own VM); a hardening TODO
    journal(db, "system", "job created (kind=" + cfg_kind(a) + ", goal=" + goal + ")")
    sqlite_close(db)
}
// spawn_worker detaches the worker: setsid + closed stdin + log redirect, so it survives
// its parent exiting (a local shell, or the ssh session that launched it via _boot).
func spawn_worker(jobid) {
    self := args()[0]
    logp := roam_home() + "/" + jobid + ".log"
    system("setsid " + self + " _work " + jobid + " </dev/null >> " + logp + " 2>&1 &")
}

// ---- target resolution: a control target is a local jobid or a remote host handle ----
func hosts_path(h) (p) { p = roam_home() + "/hosts/" + h }
// resolve_target maps a CLI target to (host, jobid, remote). `last` reads the last
// dispatch; a name with a ~/.roam/hosts/<name> handle is remote; anything else is a
// local jobid.
func resolve_target(arg) (host, jobid, remote) {
    host = ""
    remote = 0
    t := arg
    if arg == "last" { t = trim(read_file(roam_home() + "/last")) }
    hv := trim(read_file(hosts_path(t)))
    if hv != "" {
        host = t
        jobid = hv
        remote = 1
        return host, jobid, remote
    }
    jobid = t
}
// remote_exec runs the SAME roam subcommand on the remote against its own journal; ssh
// streams the remote's stdout/stderr straight back (so `attach` is live over the pipe).
func remote_exec(host, sub, jobid, extra) (rc) {
    rc = system("ssh " + host + " '~/.roam/roam " + sub + " " + jobid + extra + "'")
}

// ---- worker -------------------------------------------------------------------

// drain_mailbox applies every unconsumed steering message at a safe checkpoint.
func drain_mailbox(db) {
    rows := sqlite_query(db, "SELECT id, cmd, arg FROM mailbox WHERE consumed = 0 ORDER BY id")
    ms := parse(rows, []MRow{})
    for _, m := range ms {
        if m.cmd == "pause"  { state_set(db, "status", "paused")   journal(db, "control", "paused") }
        if m.cmd == "resume" { state_set(db, "status", "running")  journal(db, "control", "resumed") }
        if m.cmd == "stop"   { state_set(db, "status", "stopped")  journal(db, "control", "stop requested") }
        if m.cmd == "note"   { journal(db, "steer", m.arg) }
        sqlite_exec(db, "UPDATE mailbox SET consumed = 1 WHERE id = ?", []string{str(m.id)})
    }
}

// ============================================================================
// The LLM tool-loop (#agent). No SDK — raw HTTP to the Anthropic Messages API.
// The manual agentic loop: POST -> parse content -> run tool_use blocks ->
// append the assistant turn (verbatim) + a tool_result user turn -> repeat,
// until the model stops asking for tools or calls `finish`. Hard budgets
// (iterations, cumulative tokens) freeze the run; a scoped workdir + gated
// shell bound the blast radius; every step is journaled.
// ============================================================================

func first_n(s, k) (out) {
    if len(s) <= k { out = s  return out }
    out = substr(s, 0, k) + "…[truncated]"
}

// junquote reverses jstr: strip the outer quotes of a JSON string token and
// unescape. Numbers/bools (no leading quote) pass through unchanged.
func junquote(s) (out) {
    n := len(s)
    if n < 2 { out = s  return out }
    if substr(s, 0, 1) != "\"" { out = s  return out }
    inner := substr(s, 1, n - 1)
    b := bytes(inner)
    parts := []string{}
    i := 0
    for i < len(b) {
        c := byte_at(b, i)
        if c == 92 && i + 1 < len(b) {
            d := byte_at(b, i + 1)
            if d == 110 { parts = append(parts, "\n") } else {
            if d == 116 { parts = append(parts, "\t") } else {
            if d == 114 { parts = append(parts, "\r") } else {
            if d == 34 { parts = append(parts, "\"") } else {
            if d == 92 { parts = append(parts, "\\") } else {
            if d == 47 { parts = append(parts, "/") } else {
                parts = append(parts, substr(inner, i + 1, i + 2))
            }}}}}}
            i = i + 2
        } else {
            parts = append(parts, substr(inner, i, i + 1))
            i = i + 1
        }
    }
    out = join(parts, "")
}

func atoi_json(j, path) (n) {
    v, _ := json_get(j, path)
    n = 0
    if v != "" { n = atoi(v) }
}

func mkdir_p2(a, b) { mkdir(a)  mkdir(b) }

// safe_path confines a tool path to the job workdir: no absolute paths, no `..`.
func safe_path(workdir, p) (full, ok) {
    ok = 1
    if has_prefix(p, "/") { ok = 0  full = ""  return full, ok }
    if contains(p, "..") { ok = 0  full = ""  return full, ok }
    full = workdir + "/" + p
}

// pipes_to_shell: does the command pipe output INTO sh/bash (curl … | sh)? Checked by
// splitting on "|" and testing whether a pipe segment's first token is exactly `sh` or
// `bash` — so a regex alternative like `hmac_sha256|sha256_bytes` (first token
// "sha256_bytes", not "sh") no longer false-positives the way a bare "|sh" substring did.
func pipes_to_shell(lc) (b) {
    b = 0
    parts := split(lc, "|")
    i := 1
    for i < len(parts) {
        first := split(trim(parts[i]), " ")[0]
        if first == "sh" || first == "bash" { b = 1  return b }
        i = i + 1
    }
}

// is_destructive: does a shell command look data-destroying or system-altering? A
// deliberately over-eager classifier — false positives just ask for approval (safe);
// the cost of a false negative (an un-gated `rm -rf`) is much higher. The harness owns
// this decision, not the model (which doesn't know your security boundary).
func is_destructive(cmd) (b) {
    b = 0
    lc := to_lower(cmd)
    // rm as a real command word (not "confirm"/"perform", which also contain "rm ")
    if has_prefix(lc, "rm ") { b = 1  return b }
    if contains(lc, " rm ") || contains(lc, "rm -") || contains(lc, ";rm ") || contains(lc, "&rm ") || contains(lc, "|rm ") { b = 1  return b }
    if pipes_to_shell(lc) == 1 { b = 1  return b }   // curl … | sh  (token-checked, not substring)
    // NOTE: no bare ">/" / "> /" redirect needle — it matches benign `2>/dev/null` and
    // every stderr/stdout suppression, which made --confirm park on almost everything.
    // Writes that clobber a real system path show up via the specific needles below.
    needles := []string{"rmdir", "dd if=", "mkfs", "shred", "truncate -", "git push", "reset --hard", "git clean -", "drop table", "drop database", "delete from", "shutdown", "reboot", "poweroff", "kill ", "pkill", "killall", "chmod -r", "chown -r", "chmod 777", "systemctl stop", "systemctl disable", "systemctl mask", "systemctl restart", "userdel", "deluser", "crontab -r", "iptables ", "/dev/sd", "mkswap", "fdisk", "parted ", "wipefs", "> /etc", "> /usr", "> /boot", "> /var", "> /root", ">/etc", ">/usr", ">/boot"}
    i := 0
    for i < len(needles) { if contains(lc, needles[i]) { b = 1  return b }  i = i + 1 }
}

// wait_for_approval parks the worker on a destructive action and blocks (polling the
// mailbox) until an operator approves/denies — or stops the job. This is the async
// human-in-the-loop gate: roam is non-interactive, so approval is a mailbox message
// (`roam approve|deny`), usable identically by a human or a supervising agent.
func wait_for_approval(db, cmd) (decision) {
    state_set(db, "pending", cmd)
    state_set(db, "status", "awaiting")
    journal(db, "confirm", "AWAITING APPROVAL for destructive command: " + first_n(cmd, 400))
    decision = ""
    for decision == "" {
        rows := sqlite_query(db, "SELECT id, cmd, arg FROM mailbox WHERE consumed = 0 ORDER BY id")
        ms := parse(rows, []MRow{})
        for _, m := range ms {
            if m.cmd == "approve" { decision = "approve" }
            if m.cmd == "deny" { decision = "deny" }
            if m.cmd == "stop" { decision = "stop" }
            sqlite_exec(db, "UPDATE mailbox SET consumed = 1 WHERE id = ?", []string{str(m.id)})
        }
        if decision == "" { sleep(1000) }
    }
    state_set(db, "pending", "")
    if decision == "stop" {
        state_set(db, "status", "stopped")
        journal(db, "confirm", "stopped by operator during approval wait")
        return decision
    }
    if decision == "approve" {
        state_set(db, "status", "running")
        journal(db, "confirm", "approved by operator")
        return decision
    }
    // deny — count it against the deny budget so a stubborn agent that keeps re-parking
    // on destructive variants self-terminates instead of parking forever.
    maxd := atoi(state_get(db, "maxdenials"))
    if maxd < 1 { maxd = 3 }
    denials := atoi(state_get(db, "denials")) + 1
    state_set(db, "denials", str(denials))
    if denials >= maxd {
        state_set(db, "status", "halted")
        journal(db, "confirm", "denied by operator; deny budget exhausted (" + str(denials) + "/" + str(maxd) + ") — halting")
        decision = "halt"
        return decision
    }
    state_set(db, "status", "running")
    journal(db, "confirm", "denied by operator (" + str(denials) + "/" + str(maxd) + ")")
}

// judge_call makes a single, tool-less LLM call for the active provider and returns the
// response text — the independent second opinion used by the goal-verify pass.
// judge_call makes a single, tool-less LLM call for the active provider and returns the
// response text (empty string on any error/empty content — the caller treats that as
// inconclusive, never as a failure).
func judge_call(db, sys, usr) (txt) {
    txt = ""
    key := state_get(db, "api_key")
    model := state_get(db, "model")
    apibase := state_get(db, "api_base")
    if state_get(db, "provider") == "openai" {
        body := "{\"model\":" + jstr(model) + ",\"max_tokens\":500,\"messages\":[{\"role\":\"system\",\"content\":" + jstr(sys) + "},{\"role\":\"user\",\"content\":" + jstr(usr) + "}]}"
        hdrs := []string{"Authorization: Bearer " + key, "content-type: application/json"}
        st, resp := http_post_retry(apibase + "/chat/completions", hdrs, body)
        if st != 200 { return txt }
        c, _ := json_get(resp, ".choices[0].message.content")
        txt = junquote(c)
        if txt == "" || txt == "null" {   // some models put the answer in `reasoning`
            r, _ := json_get(resp, ".choices[0].message.reasoning")
            txt = junquote(r)
        }
        if txt == "null" { txt = "" }
        return txt
    }
    body := "{\"model\":" + jstr(model) + ",\"max_tokens\":500,\"system\":" + jstr(sys) + ",\"messages\":[{\"role\":\"user\",\"content\":" + jstr(usr) + "}]}"
    st, resp := call_api(apibase + "/v1/messages", key, body)
    if st != 200 { return txt }
    c, _ := json_get(resp, ".content[0].text")
    txt = junquote(c)
    if txt == "null" { txt = "" }
}

// verify_goal is the goal-verify pass: an independent judge decides whether the goal was
// genuinely met — from EVIDENCE (the actual workdir listing + the action log), not the
// agent's self-report. Returns "pass" | "fail" | "inconclusive". It is deliberately
// FAIL-OPEN: only a confident explicit "VERDICT: FAIL" blocks the finish; an empty or
// unparseable verdict (a flaky/incapable judge model) is "inconclusive" and must NOT
// block a completing agent — a broken verifier should never override real work.
func verify_goal(db, workdir, goal, claim) (verdict) {
    verdict = "inconclusive"
    lf := workdir + "/.roam_verify_ls"
    system("cd " + workdir + " && ls -la > " + lf + " 2>&1")
    listing := first_n(read_file(lf), 2500)
    jlog := first_n(sqlite_query(db, "SELECT kind, msg FROM journal WHERE kind IN ('llm', 'tool', 'confirm') ORDER BY id DESC LIMIT 25"), 3000)
    sys := "You are a strict, independent verifier. You are given a GOAL, the agent's completion CLAIM, and EVIDENCE about the actual resulting state (a listing of the working directory and a log of the actions the agent took). Judge ONLY from the evidence whether the goal was genuinely and fully accomplished — do NOT take the agent's claim at face value. Reply with EXACTLY one line: 'VERDICT: PASS - <one-sentence reason>' if the goal is fully met, otherwise 'VERDICT: FAIL - <one-sentence reason naming what is missing>'."
    usr := "GOAL:\n" + goal + "\n\nAGENT CLAIM:\n" + claim + "\n\nWORKDIR LISTING:\n" + listing + "\n\nACTION LOG (most recent first, JSON):\n" + jlog + "\n\nYour verdict line:"
    txt := judge_call(db, sys, usr)
    up := to_upper(txt)
    if contains(up, "VERDICT: PASS") { verdict = "pass" } else {
        if contains(up, "VERDICT: FAIL") { verdict = "fail" }
    }
    journal(db, "verify", "verdict=" + verdict + ": " + first_n(txt, 200))
}

// handle_finish decides what a `finish` tool call means. --verify off: accepted as-is.
// --verify on: pass -> accept; inconclusive -> accept (fail-open) with a note; fail ->
// "not done, keep working" (another shot) until the verify budget halts the job.
// Returns (tool_result_text, done) — done==1 means accept the finish.
func handle_finish(db, workdir, summary) (result, done) {
    done = 0
    if state_get(db, "verify") != "1" { done = 1  result = summary  return result, done }
    v := verify_goal(db, workdir, state_get(db, "goal"), summary)
    if v == "pass" { done = 1  result = "Goal verified."  return result, done }
    if v == "inconclusive" { done = 1  result = "Finish accepted (verifier inconclusive)."  journal(db, "verify", "inconclusive verdict — accepting finish (fail-open)")  return result, done }
    // fail
    vf := atoi(state_get(db, "vfails")) + 1
    state_set(db, "vfails", str(vf))
    maxv := atoi(state_get(db, "maxverify"))
    if maxv < 1 { maxv = 2 }
    if vf >= maxv {
        state_set(db, "status", "halted")
        journal(db, "verify", "verify budget exhausted (" + str(vf) + "/" + str(maxv) + ") — halting")
        result = "Verification failed repeatedly; the verify budget is exhausted and the job is halting."
        return result, done
    }
    result = "NOT DONE — an independent verification found the goal is not satisfied. Keep working to fully satisfy the goal, then call finish again."
}

// build_tools_json is the Anthropic `tools` array. run_shell is present only
// when the job was dispatched with --allow-shell (default: file ops only).
func build_tools_json(allow_shell) (t) {
    parts := []string{}
    if allow_shell == 1 {
        parts = append(parts, "{\"name\":\"run_shell\",\"description\":\"Run a shell command in the working directory; returns combined stdout+stderr and the exit code.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"command\":{\"type\":\"string\",\"description\":\"The shell command to run.\"}},\"required\":[\"command\"]}}")
    }
    parts = append(parts, "{\"name\":\"read_file\",\"description\":\"Read a file. Path is relative to the working directory.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"}},\"required\":[\"path\"]}}")
    parts = append(parts, "{\"name\":\"write_file\",\"description\":\"Write a file. Path is relative to the working directory.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"path\",\"content\"]}}")
    parts = append(parts, "{\"name\":\"finish\",\"description\":\"Call this when the goal is complete. Provide a short summary of what was accomplished.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"summary\":{\"type\":\"string\"}},\"required\":[\"summary\"]}}")
    t = "[" + join(parts, ",") + "]"
}

// exec_tool runs one tool call. `argsjson` is the decoded tool-input OBJECT (e.g.
// {"command":"ls"}) — the same shape for both providers (Anthropic .input, or an
// OpenAI tool_call's JSON-decoded .function.arguments). Returns (result, is_error).
func exec_tool(db, name, argsjson, workdir, allow_shell) (result, iserr) {
    iserr = 0
    if name == "run_shell" {
        if allow_shell == 0 { result = "run_shell is disabled for this job (re-dispatch with --allow-shell to enable)"  iserr = 1  return result, iserr }
        cmdq, _ := json_get(argsjson, ".command")
        cmd := junquote(cmdq)
        // confirm-gate: a destructive command parks for async operator approval.
        if state_get(db, "confirm") == "1" && is_destructive(cmd) == 1 {
            dec := wait_for_approval(db, cmd)
            if dec == "deny" { journal(db, "tool", "run_shell DENIED: " + first_n(cmd, 200))  result = "The operator DENIED this command. Do not retry it or a variant — choose a different, non-destructive approach, or explain why you cannot proceed."  return result, iserr }
            if dec == "halt" { result = "The operator denied this repeatedly; the deny budget is exhausted and the job is halting."  iserr = 1  return result, iserr }
            if dec == "stop" { result = "run cancelled: the job was stopped during approval"  iserr = 1  return result, iserr }
            // approved -> fall through and execute
        }
        journal(db, "tool", "run_shell: " + first_n(cmd, 200))
        outf := workdir + "/.roam_tool_out"
        rc := system("cd " + workdir + " && (" + cmd + ") > " + outf + " 2>&1")
        result = first_n(read_file(outf), 6000) + "\n[exit " + str(rc) + "]"
        return result, iserr
    }
    if name == "read_file" {
        pq, _ := json_get(argsjson, ".path")
        p := junquote(pq)
        full, ok := safe_path(workdir, p)
        if ok == 0 { result = "path not allowed (must be relative, inside the workdir): " + p  iserr = 1  return result, iserr }
        journal(db, "tool", "read_file: " + p)
        result = first_n(read_file(full), 6000)
        return result, iserr
    }
    if name == "write_file" {
        pq, _ := json_get(argsjson, ".path")
        cq, _ := json_get(argsjson, ".content")
        p := junquote(pq)
        content := junquote(cq)
        full, ok := safe_path(workdir, p)
        if ok == 0 { result = "path not allowed (must be relative, inside the workdir): " + p  iserr = 1  return result, iserr }
        journal(db, "tool", "write_file: " + p + " (" + str(len(content)) + " bytes)")
        write_file(full, content)
        result = "wrote " + str(len(content)) + " bytes to " + p
        return result, iserr
    }
    if name == "finish" {
        sq, _ := json_get(argsjson, ".summary")
        result = junquote(sq)
        return result, iserr
    }
    result = "unknown tool: " + name
    iserr = 1
}

// agent_drain applies steering at a loop checkpoint: "stop" halts; a note is
// returned (prefixed "note:") to be injected as an operator message next turn.
func agent_drain(db) (sig) {
    sig = ""
    rows := sqlite_query(db, "SELECT id, cmd, arg FROM mailbox WHERE consumed = 0 ORDER BY id")
    ms := parse(rows, []MRow{})
    for _, m := range ms {
        if m.cmd == "stop" { sig = "stop" }
        if m.cmd == "note" { journal(db, "steer", m.arg)  if sig != "stop" { sig = "note:" + m.arg } }
        sqlite_exec(db, "UPDATE mailbox SET consumed = 1 WHERE id = ?", []string{str(m.id)})
    }
}

// http_post_retry POSTs one request, retrying transient 429/5xx a few times. Returns
// (status, body). status 0 means the transport itself failed.
func http_post_retry(url, hdrs, body) (status, resp) {
    tries := 0
    for tries < 4 {
        st, rb, er := http_request("POST", url, hdrs, body)
        if st == 200 { status = st  resp = rb  return status, resp }
        if st == 429 || st >= 500 { tries = tries + 1  sleep(2000 * tries)  continue }
        // transport error (st==0) or a non-retryable 4xx: return it
        status = st
        resp = rb
        if er != "" { resp = er }
        return status, resp
    }
    status = 429
    resp = "retries exhausted"
}
func call_api(url, key, body) (status, resp) {
    hdrs := []string{"x-api-key: " + key, "anthropic-version: 2023-06-01", "content-type: application/json"}
    status, resp = http_post_retry(url, hdrs, body)
}

var AGENT_SYSTEM = "You are roam, an autonomous agent running unattended on a remote machine. Work toward the user's goal using the provided tools. You are operating autonomously: the user is not watching in real time and cannot answer questions mid-task, so do not ask for confirmation — for reversible actions that follow from the goal, just proceed. All file paths are relative to your working directory. When the goal is complete, call the finish tool with a short summary. Keep any text between tool calls to one brief sentence."

// agent_loop is the manual Anthropic tool-use loop with hard budgets.
func agent_loop(db, jobid) {
    key := state_get(db, "api_key")
    model := state_get(db, "model")
    goal := state_get(db, "goal")
    apibase := state_get(db, "api_base")
    maxiter := atoi(state_get(db, "maxiter"))
    tokbudget := atoi(state_get(db, "tokbudget"))
    allow_shell := 0
    if state_get(db, "allow_shell") == "1" { allow_shell = 1 }
    if key == "" { journal(db, "error", "no api_key set for this job")  state_set(db, "status", "error")  return }

    workdir := roam_home() + "/work/" + jobid
    mkdir_p2(roam_home() + "/work", workdir)
    url := apibase + "/v1/messages"
    tools := build_tools_json(allow_shell)

    journal(db, "system", "agent loop started (model=" + model + ", maxiter=" + str(maxiter) + ", tokens<=" + str(tokbudget) + ", shell=" + str(allow_shell) + ")")
    // messages[] accumulated as a JSON-fragment string (comma-joined turns).
    msgs := "{\"role\":\"user\",\"content\":" + jstr(goal) + "}"
    iters := 0
    spent := 0
    done := 0
    for done == 0 {
        sig := agent_drain(db)
        if sig == "stop" { journal(db, "system", "stopped by user")  state_set(db, "status", "stopped")  sqlite_close(db)  return }
        if has_prefix(sig, "note:") { msgs = msgs + ",{\"role\":\"user\",\"content\":" + jstr("[operator note] " + substr(sig, 5, len(sig))) + "}" }

        if iters >= maxiter { journal(db, "budget", "iteration budget reached (" + str(maxiter) + ") — halting")  state_set(db, "status", "halted")  sqlite_close(db)  return }
        if spent >= tokbudget { journal(db, "budget", "token budget reached (" + str(spent) + "/" + str(tokbudget) + ") — halting")  state_set(db, "status", "halted")  sqlite_close(db)  return }

        body := "{\"model\":" + jstr(model) + ",\"max_tokens\":16000,\"system\":" + jstr(AGENT_SYSTEM) + ",\"tools\":" + tools + ",\"messages\":[" + msgs + "]}"
        status, resp := call_api(url, key, body)
        if status != 200 { journal(db, "error", "api status " + str(status) + ": " + first_n(resp, 400))  state_set(db, "status", "error")  sqlite_close(db)  return }

        spent = spent + atoi_json(resp, ".usage.input_tokens") + atoi_json(resp, ".usage.output_tokens")
        iters = iters + 1
        state_set(db, "tokens", str(spent))
        state_set(db, "iters", str(iters))

        // append the assistant turn VERBATIM (content array preserved as-is)
        content, _ := json_get(resp, ".content")
        msgs = msgs + ",{\"role\":\"assistant\",\"content\":" + content + "}"

        // walk content blocks: journal text, run tools, collect tool_result blocks
        results := []string{}
        finished := 0
        finishmsg := ""
        bi := 0
        for done == 0 {
            btype, okb := json_get(resp, ".content[" + str(bi) + "].type")
            if okb != "" { done = -1 }   // notfound -> end of blocks (sentinel, reset below)
            if done == 0 {
                bt := junquote(btype)
                if bt == "text" {
                    txt, _ := json_get(resp, ".content[" + str(bi) + "].text")
                    t := junquote(txt)
                    if t != "" { journal(db, "llm", t) }
                }
                if bt == "tool_use" {
                    tid, _ := json_get(resp, ".content[" + str(bi) + "].id")
                    tnm, _ := json_get(resp, ".content[" + str(bi) + "].name")
                    arg, _ := json_get(resp, ".content[" + str(bi) + "].input")
                    id := junquote(tid)
                    nm := junquote(tnm)
                    res, iserr := exec_tool(db, nm, arg, workdir, allow_shell)
                    if nm == "finish" {
                        fres, fdone := handle_finish(db, workdir, res)
                        res = fres
                        if fdone == 1 { finished = 1  finishmsg = res }
                    }
                    errflag := "false"
                    if iserr == 1 { errflag = "true" }
                    results = append(results, "{\"type\":\"tool_result\",\"tool_use_id\":" + jstr(id) + ",\"content\":" + jstr(res) + ",\"is_error\":" + errflag + "}")
                }
                bi = bi + 1
            }
        }
        done = 0   // reset the inner-loop sentinel

        if is_terminal(state_get(db, "status")) == 1 { sqlite_close(db)  return }   // stopped during an approval wait
        if finished == 1 { journal(db, "system", "agent finished: " + finishmsg)  state_set(db, "status", "done")  sqlite_close(db)  return }

        stop, _ := json_get(resp, ".stop_reason")
        if junquote(stop) != "tool_use" {
            journal(db, "system", "agent ended its turn (stop_reason=" + junquote(stop) + ")")
            state_set(db, "status", "done")
            sqlite_close(db)
            return
        }
        if len(results) == 0 {
            journal(db, "error", "stop_reason=tool_use but no tool_result produced — halting")
            state_set(db, "status", "error")  sqlite_close(db)  return
        }
        msgs = msgs + ",{\"role\":\"user\",\"content\":[" + join(results, ",") + "]}"
    }
    sqlite_close(db)
}

// ---- OpenAI-compatible provider (OpenRouter, etc.) ----------------------------
// Same agent, different wire shape: Bearer auth, /chat/completions, tools wrapped in
// {"type":"function",...}, tool_calls with args as a JSON STRING, and per-call
// {"role":"tool",...} result messages. Shares exec_tool / budgets / mailbox / journal.

func build_tools_openai(allow_shell) (t) {
    parts := []string{}
    if allow_shell == 1 {
        parts = append(parts, "{\"type\":\"function\",\"function\":{\"name\":\"run_shell\",\"description\":\"Run a shell command in the working directory; returns combined stdout+stderr and the exit code.\",\"parameters\":{\"type\":\"object\",\"properties\":{\"command\":{\"type\":\"string\"}},\"required\":[\"command\"]}}}")
    }
    parts = append(parts, "{\"type\":\"function\",\"function\":{\"name\":\"read_file\",\"description\":\"Read a file. Path is relative to the working directory.\",\"parameters\":{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"}},\"required\":[\"path\"]}}}")
    parts = append(parts, "{\"type\":\"function\",\"function\":{\"name\":\"write_file\",\"description\":\"Write a file. Path is relative to the working directory.\",\"parameters\":{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"path\",\"content\"]}}}")
    parts = append(parts, "{\"type\":\"function\",\"function\":{\"name\":\"finish\",\"description\":\"Call this when the goal is complete. Provide a short summary of what was accomplished.\",\"parameters\":{\"type\":\"object\",\"properties\":{\"summary\":{\"type\":\"string\"}},\"required\":[\"summary\"]}}}")
    t = "[" + join(parts, ",") + "]"
}

func agent_loop_openai(db, jobid) {
    key := state_get(db, "api_key")
    model := state_get(db, "model")
    goal := state_get(db, "goal")
    apibase := state_get(db, "api_base")
    maxiter := atoi(state_get(db, "maxiter"))
    tokbudget := atoi(state_get(db, "tokbudget"))
    allow_shell := 0
    if state_get(db, "allow_shell") == "1" { allow_shell = 1 }
    if key == "" { journal(db, "error", "no api_key set for this job")  state_set(db, "status", "error")  return }

    workdir := roam_home() + "/work/" + jobid
    mkdir_p2(roam_home() + "/work", workdir)
    url := apibase + "/chat/completions"
    tools := build_tools_openai(allow_shell)
    hdrs := []string{"Authorization: Bearer " + key, "content-type: application/json"}

    journal(db, "system", "agent loop started [openai] (model=" + model + ", maxiter=" + str(maxiter) + ", tokens<=" + str(tokbudget) + ", shell=" + str(allow_shell) + ")")
    msgs := "{\"role\":\"system\",\"content\":" + jstr(AGENT_SYSTEM) + "},{\"role\":\"user\",\"content\":" + jstr(goal) + "}"
    iters := 0
    spent := 0
    done := 0
    for done == 0 {
        sig := agent_drain(db)
        if sig == "stop" { journal(db, "system", "stopped by user")  state_set(db, "status", "stopped")  sqlite_close(db)  return }
        if has_prefix(sig, "note:") { msgs = msgs + ",{\"role\":\"user\",\"content\":" + jstr("[operator note] " + substr(sig, 5, len(sig))) + "}" }

        if iters >= maxiter { journal(db, "budget", "iteration budget reached (" + str(maxiter) + ") — halting")  state_set(db, "status", "halted")  sqlite_close(db)  return }
        if spent >= tokbudget { journal(db, "budget", "token budget reached (" + str(spent) + "/" + str(tokbudget) + ") — halting")  state_set(db, "status", "halted")  sqlite_close(db)  return }

        body := "{\"model\":" + jstr(model) + ",\"max_tokens\":16000,\"messages\":[" + msgs + "],\"tools\":" + tools + ",\"tool_choice\":\"auto\"}"
        status, resp := http_post_retry(url, hdrs, body)
        if status != 200 { journal(db, "error", "api status " + str(status) + ": " + first_n(resp, 400))  state_set(db, "status", "error")  sqlite_close(db)  return }

        spent = spent + atoi_json(resp, ".usage.prompt_tokens") + atoi_json(resp, ".usage.completion_tokens")
        iters = iters + 1
        state_set(db, "tokens", str(spent))
        state_set(db, "iters", str(iters))

        // append the assistant message VERBATIM (preserves tool_calls for pairing)
        amsg, _ := json_get(resp, ".choices[0].message")
        msgs = msgs + "," + amsg
        ctq, _ := json_get(resp, ".choices[0].message.content")
        ct := junquote(ctq)
        if ct != "" && ct != "null" { journal(db, "llm", ct) }

        finished := 0
        finishmsg := ""
        toolmsgs := []string{}
        ti := 0
        for done == 0 {
            idq, okt := json_get(resp, ".choices[0].message.tool_calls[" + str(ti) + "].id")
            if okt != "" { done = -1 }
            if done == 0 {
                nmq, _ := json_get(resp, ".choices[0].message.tool_calls[" + str(ti) + "].function.name")
                argq, _ := json_get(resp, ".choices[0].message.tool_calls[" + str(ti) + "].function.arguments")
                id := junquote(idq)
                nm := junquote(nmq)
                argsjson := junquote(argq)   // args arrive as a JSON string -> decode to the object
                res, iserr := exec_tool(db, nm, argsjson, workdir, allow_shell)
                if nm == "finish" {
                    fres, fdone := handle_finish(db, workdir, res)
                    res = fres
                    if fdone == 1 { finished = 1  finishmsg = res }
                }
                _ = iserr
                toolmsgs = append(toolmsgs, "{\"role\":\"tool\",\"tool_call_id\":" + jstr(id) + ",\"content\":" + jstr(res) + "}")
                ti = ti + 1
            }
        }
        done = 0

        if is_terminal(state_get(db, "status")) == 1 { sqlite_close(db)  return }   // stopped during an approval wait

        i := 0
        for i < len(toolmsgs) { msgs = msgs + "," + toolmsgs[i]  i = i + 1 }

        if finished == 1 { journal(db, "system", "agent finished: " + finishmsg)  state_set(db, "status", "done")  sqlite_close(db)  return }
        fr, _ := json_get(resp, ".choices[0].finish_reason")
        if junquote(fr) != "tool_calls" {
            journal(db, "system", "agent ended its turn (finish_reason=" + junquote(fr) + ")")
            state_set(db, "status", "done")
            sqlite_close(db)
            return
        }
        if len(toolmsgs) == 0 {
            journal(db, "error", "finish_reason=tool_calls but no tool_calls parsed — halting")
            state_set(db, "status", "error")  sqlite_close(db)  return
        }
    }
    sqlite_close(db)
}

// ---- debri / Devin (SWE-1.x) provider -----------------------------------------
// A different KIND of engine: instead of running roam's own tool-loop, hand the whole
// goal to the `devin` CLI via `debri`. Devin runs its own agentic loop under a flat
// subscription — no per-token cost, which is the point. roam keeps everything around
// it: dispatch, self-replication, the journal, and stop. We spawn debri detached in the
// background streaming JSONL to a file, tail that file into the journal so `attach` is
// live, and honor the mailbox stop by SIGTERM'ing debri (its signal handler tears down
// the devin/tmux session cleanly). No LLM key, no token budget — those flags are moot.
//
// debri JSONL events (one JSON object per line): {"event":"init","status":"ok"} ·
// {"event":"chunk","content":"..."} · {"event":"done","content":"...","elapsed_ms":N} ·
// {"event":"error","error":"...","elapsed_ms":N}.
var DEBRI_DONE_MARKER = "ROAM_SESSION_COMPLETE_7f3a"

func agent_loop_debri(db, jobid) {
    model := state_get(db, "model")
    if has_prefix(model, "claude") { model = "SWE-1.7" }   // default when --model wasn't given
    perm := state_get(db, "debri_perm")
    if perm == "" { perm = "dangerous" }
    stable := state_get(db, "debri_stable")
    if stable == "" { stable = "300000" }
    goal := state_get(db, "goal")
    workdir := roam_home() + "/work/" + jobid
    mkdir_p2(roam_home() + "/work", workdir)

    // Ship the goal via a file (debri --file) so no shell-escaping of the prompt is needed.
    // Append a done-marker instruction: debri ends the session the moment devin prints the
    // marker line, so a cooperative session finishes promptly instead of waiting out the
    // (necessarily long) silence safety cap.
    goalfile := roam_home() + "/" + jobid + ".goal"
    marked := goal + "\n\n---\nIMPORTANT: When you have COMPLETELY finished the task (all work done, and any repo created/committed/pushed), print this EXACT line by itself as your final output, with nothing after it:\n" + DEBRI_DONE_MARKER + "\n"
    write_file(goalfile, marked)
    streamfile := roam_home() + "/" + jobid + ".debri.jsonl"
    write_file(streamfile, "")

    journal(db, "system", "debri engine started (model=" + model + ", perm=" + perm + ", stable=" + stable + "ms, workdir=" + workdir + ")")
    cmd := "debri --model \"" + model + "\" --permission-mode " + perm + " --working-dir " + workdir + " --stable-timeout " + stable + " --done-marker " + DEBRI_DONE_MARKER + " --stream --file " + goalfile + " > " + streamfile + " 2>&1 &"
    if system(cmd) != 0 {
        journal(db, "error", "failed to launch debri — install the binary on the target: curl -fsSL https://github.com/javimosch/debri/releases/latest/download/debri -o ~/.local/bin/debri && chmod +x ~/.local/bin/debri ; then ensure `devin` is authenticated and `tmux` is present")
        state_set(db, "status", "error")  sqlite_close(db)  return
    }

    // Tail the stream file, journaling each COMPLETE (newline-terminated) JSONL line once.
    // split(content,"\n") yields (#newlines)+1 elems; the last is the partial/empty tail,
    // so #complete lines = len(parts)-1 — robust against reading a half-written last line.
    lastn := 0
    done := 0
    for done == 0 {
        sig := agent_drain(db)
        if sig == "stop" {
            system("pkill -TERM -f 'debri --model'")
            journal(db, "system", "stopped by user (SIGTERM -> debri tears down devin session)")
            state_set(db, "status", "stopped")  sqlite_close(db)  return
        }
        // (a steering note can't be injected into a running devin session; agent_drain
        //  still journals it as `steer` for the record.)
        content := read_file(streamfile)
        parts := split(content, "\n")
        nc := len(parts) - 1
        if nc < 0 { nc = 0 }
        i := lastn
        for i < nc {
            line := trim(parts[i])
            if line != "" {
                ev, _ := json_get(line, ".event")
                e := junquote(ev)
                if e == "init" { journal(db, "devin", "session started") }
                if e == "chunk" {
                    c, _ := json_get(line, ".content")
                    tx := junquote(c)
                    if trim(tx) != "" { journal(db, "devin", tx) }
                }
                if e == "done" {
                    c, _ := json_get(line, ".content")
                    fin := junquote(c)
                    if trim(fin) != "" { journal(db, "devin", fin) }
                    journal(db, "system", "debri finished (devin session complete)")
                    state_set(db, "status", "done")  done = 1
                }
                if e == "error" {
                    er, _ := json_get(line, ".error")
                    journal(db, "error", "debri: " + junquote(er))
                    state_set(db, "status", "error")  done = 1
                }
            }
            i = i + 1
        }
        lastn = nc
        if done == 0 { sleep(3000) }
    }
    sqlite_close(db)
}

func cmd_work(a) {
    if len(a) < 3 { write(2, "roam _work: needs <jobid>\n")  exit(64) }
    jobid := a[2]
    db := open_db(db_path(jobid))
    ensure_schema(db)
    journal(db, "system", "worker started")
    state_set(db, "status", "running")
    if state_get(db, "kind") == "agent" {
        if state_get(db, "provider") == "debri" { agent_loop_debri(db, jobid)  return }
        if state_get(db, "provider") == "openai" { agent_loop_openai(db, jobid)  return }
        agent_loop(db, jobid)
        return
    }
    // "tick" (skeleton) mode: trivial work loop (no LLM).
    every := atoi(state_get(db, "every"))   // seconds (user unit)
    if every < 1 { every = 10 }
    naptime := every * 1000                  // sleep() is milliseconds
    done := 0
    for done == 0 {
        drain_mailbox(db)
        st := state_get(db, "status")
        if st == "stopped" {
            journal(db, "system", "worker stopped")
            done = 1
        } else {
            if st != "paused" {
                // one unit of (trivial, skeleton) work
                tick := atoi(state_get(db, "tick")) + 1
                state_set(db, "tick", str(tick))
                journal(db, "work", "tick " + str(tick))
            }
            sleep(naptime)
        }
    }
    sqlite_close(db)
}

// ---- controller commands ------------------------------------------------------

// agent config parsed from the CLI flags (shared by local send and remote boot).
func cfg_model(a) (v) { v = flag(a, "--model", "claude-opus-4-8") }
func cfg_maxiter(a) (v) { v = flag(a, "--max-iters", "25") }
func cfg_tokens(a) (v) { v = flag(a, "--tokens", "300000") }
func cfg_apibase(a) (v) { v = flag(a, "--api-base", "https://api.anthropic.com") }
func cfg_shell(a) (v) { v = "0"  if has_flag(a, "--allow-shell") { v = "1" } }
func cfg_kind(a) (v) { v = "agent"  if has_flag(a, "--tick") { v = "tick" } }
func cfg_provider(a) (v) { v = flag(a, "--provider", "anthropic") }
func cfg_confirm(a) (v) { v = "0"  if has_flag(a, "--confirm") { v = "1" } }
func cfg_maxdenials(a) (v) { v = flag(a, "--max-denials", "3") }
func cfg_verify(a) (v) { v = "0"  if has_flag(a, "--verify") { v = "1" } }
func cfg_maxverify(a) (v) { v = flag(a, "--max-verify", "2") }
func cfg_debri_perm(a) (v) { v = flag(a, "--debri-perm", "dangerous") }  // --provider debri: devin permission-mode
// debri declares the session done after this many ms of pane silence. devin can be silent
// for a while (cloud provisioning ~60-90s, long thinks, silent compiles), so the default
// (5000) makes it bail before devin even starts. 300000 = 5min safety cap; the done-marker
// (below) is what ends a cooperative session promptly.
func cfg_debri_stable(a) (v) { v = flag(a, "--debri-stable", "300000") }
// get_key: the provider-neutral ROAM_API_KEY wins, else ANTHROPIC_API_KEY.
func get_key() (k) { k = env("ROAM_API_KEY")  if k == "" { k = env("ANTHROPIC_API_KEY") } }

func cmd_send(a) {
    to := flag(a, "--to", "")
    goal := flag_rest(a, "--goal")
    every := flag(a, "--every", "10")
    local := has_flag(a, "--local")
    model := cfg_model(a)  maxiter := cfg_maxiter(a)  tokbudget := cfg_tokens(a)
    apibase := cfg_apibase(a)  allow_shell := cfg_shell(a)  kind := cfg_kind(a)
    provider := cfg_provider(a)  confirm := cfg_confirm(a)  maxdenials := cfg_maxdenials(a)
    verify := cfg_verify(a)  maxverify := cfg_maxverify(a)
    key := get_key()
    jobid := to_hex(rand_bytes(4))   // decided by the controller, shipped to the remote

    if local {
        init_job(jobid, goal, every, "local", a)
        spawn_worker(jobid)
        write_last(jobid)
        println("{\"ok\":true,\"mode\":\"local\",\"kind\":" + jstr(kind) + ",\"jobid\":" + jstr(jobid) + "}")
        return
    }

    if to == "" { write(2, "{\"ok\":false,\"error\":\"--to <host> required (or --local)\"}\n")  exit(64) }
    if kind == "agent" && provider != "debri" && key == "" { write(2, "{\"ok\":false,\"error\":\"ANTHROPIC_API_KEY not set (agent mode); export it, or use --tick / --provider debri\"}\n")  exit(64) }
    // self-replicate: ship this exact binary to the remote, then boot the job there.
    self := args()[0]
    if system("ssh " + to + " 'mkdir -p ~/.roam'") != 0 { write(2, "{\"ok\":false,\"error\":\"ssh " + to + " failed\"}\n")  exit(100) }
    if system("scp -q " + self + " " + to + ":.roam/roam") != 0 { write(2, "{\"ok\":false,\"error\":\"scp to " + to + " failed\"}\n")  exit(100) }
    system("ssh " + to + " 'chmod +x ~/.roam/roam'")
    // config as flags; the API key rides as an env var on the remote command (kept out
    // of the arg list). --goal MUST be last (flag_rest consumes the remainder as goal).
    cfgflags := " --provider " + provider + " --model " + model + " --max-iters " + maxiter + " --tokens " + tokbudget + " --api-base " + apibase
    if allow_shell == "1" { cfgflags = cfgflags + " --allow-shell" }
    if confirm == "1" { cfgflags = cfgflags + " --confirm --max-denials " + maxdenials }
    if verify == "1" { cfgflags = cfgflags + " --verify --max-verify " + maxverify }
    if provider == "debri" { cfgflags = cfgflags + " --debri-perm " + cfg_debri_perm(a) + " --debri-stable " + cfg_debri_stable(a) }
    if kind == "tick" { cfgflags = cfgflags + " --tick" }
    // the goal is base64'd so quotes/parens/any shell-special char survive the ssh
    // single-quote wrapper (a raw --goal with a ' in it breaks the remote command).
    bootcmd := "ssh " + to + " 'ROAM_API_KEY=" + key + " ~/.roam/roam _boot " + jobid + " " + every + cfgflags + " --goal-b64 " + base64_encode(goal) + "' >/dev/null"
    // _boot inits the job DB + detaches the worker on the remote; its stdout is
    // suppressed so the controller emits exactly one JSON answer.
    if system(bootcmd) != 0 { write(2, "{\"ok\":false,\"error\":\"remote boot failed\"}\n")  exit(100) }
    mkdir(roam_home() + "/hosts")
    write_file(hosts_path(to), jobid)
    write_file(roam_home() + "/last", to)
    println("{\"ok\":true,\"mode\":\"remote\",\"kind\":" + jstr(kind) + ",\"host\":" + jstr(to) + ",\"jobid\":" + jstr(jobid) + "}")
}

// _boot (remote-side): init the job and detach the worker. jobid + every are fixed
// positional args; config comes from flags; --goal (multi-word) is last. The API key
// arrives via the ANTHROPIC_API_KEY env var on the ssh command.
func cmd_boot(a) {
    if len(a) < 4 { write(2, "roam _boot: needs <jobid> <every> [flags] --goal <goal...>\n")  exit(64) }
    jobid := a[2]
    every := a[3]
    goal := flag_rest(a, "--goal")
    gb := flag(a, "--goal-b64", "")
    if gb != "" { goal = base64_decode(gb) }   // remote path ships the goal base64'd
    init_job(jobid, goal, every, "self", a)
    spawn_worker(jobid)
    println("{\"ok\":true,\"jobid\":" + jstr(jobid) + "}")
}

func cmd_status(a) {
    if len(a) < 3 { write(2, "roam status: needs <host|jobid|last>\n")  exit(64) }
    host, jobid, remote := resolve_target(a[2])
    if remote == 1 { remote_exec(host, "status", jobid, "")  return }
    db := open_db(db_path(jobid))
    status := state_get(db, "status")
    kind := state_get(db, "kind")
    goal := state_get(db, "goal")
    started := state_get(db, "started")
    iters := state_get(db, "iters")
    tokens := state_get(db, "tokens")
    tick := state_get(db, "tick")
    pending := state_get(db, "pending")
    denials := state_get(db, "denials")
    vfails := state_get(db, "vfails")
    recent := sqlite_query(db, "SELECT id, ts, kind, msg FROM journal ORDER BY id DESC LIMIT 8")
    sqlite_close(db)
    if iters == "" { iters = "0" }
    if tokens == "" { tokens = "0" }
    if tick == "" { tick = "0" }
    if started == "" { started = "0" }
    if kind == "" { kind = "tick" }
    if denials == "" { denials = "0" }
    if vfails == "" { vfails = "0" }
    // `pending` is the destructive command awaiting approval (status == "awaiting").
    println("{\"jobid\":" + jstr(jobid) + ",\"status\":" + jstr(status) + ",\"kind\":" + jstr(kind) + ",\"goal\":" + jstr(goal) + ",\"iters\":" + iters + ",\"tokens\":" + tokens + ",\"denials\":" + denials + ",\"verify_fails\":" + vfails + ",\"tick\":" + tick + ",\"started\":" + started + ",\"pending\":" + jstr(pending) + ",\"recent\":" + recent + "}")
}

func cmd_attach(a) {
    if len(a) < 3 { write(2, "roam attach: needs <host|jobid|last>\n")  exit(64) }
    host, jobid, remote := resolve_target(a[2])
    if remote == 1 { remote_exec(host, "attach", jobid, "")  return }
    db := open_db(db_path(jobid))
    write(2, "[attach " + jobid + "] streaming journal (Ctrl-C to detach)\n")
    lastid := 0
    done := 0
    for done == 0 {
        rows := sqlite_query(db, "SELECT id, ts, kind, msg FROM journal WHERE id > ? ORDER BY id", []string{str(lastid)})
        js := parse(rows, []JRow{})
        for _, j := range js {
            // write(1,...) is an unbuffered fd write — a streaming view must show each
            // line as it lands, not block-buffered until exit (println buffers when
            // stdout isn't a TTY, so a killed `attach` would show nothing).
            write(1, "[" + str(j.ts) + "] " + j.kind + ": " + j.msg + "\n")
            lastid = j.id
        }
        st := state_get(db, "status")
        if is_terminal(st) == 1 {
            write(2, "[attach] job " + st + "\n")
            done = 1
        } else {
            sleep(1)
        }
    }
    sqlite_close(db)
}

func cmd_steer(a) {
    if len(a) < 4 { write(2, "roam steer: needs <host|jobid|last> <message>\n")  exit(64) }
    host, jobid, remote := resolve_target(a[2])
    parts := []string{}
    i := 3
    for i < len(a) { parts = append(parts, a[i])  i = i + 1 }
    msg := join(parts, " ")
    if remote == 1 { remote_exec(host, "steer", jobid, " \"" + msg + "\"")  return }
    db := open_db(db_path(jobid))
    mailbox_put(db, "note", msg)
    sqlite_close(db)
    println("{\"ok\":true,\"jobid\":" + jstr(jobid) + ",\"steered\":" + jstr(msg) + "}")
}

func cmd_ctl(a, cmd) {
    if len(a) < 3 { write(2, "roam " + cmd + ": needs <host|jobid|last>\n")  exit(64) }
    host, jobid, remote := resolve_target(a[2])
    if remote == 1 { remote_exec(host, cmd, jobid, "")  return }
    db := open_db(db_path(jobid))
    mailbox_put(db, cmd, "")
    sqlite_close(db)
    println("{\"ok\":true,\"jobid\":" + jstr(jobid) + ",\"cmd\":" + jstr(cmd) + "}")
}

func usage() {
    write(2, "roam — leave a working agent on a remote box\n")
    write(2, "usage:\n")
    write(2, "  roam send --to <host> [flags] --goal <text>   # dispatch an agent (--goal LAST)\n")
    write(2, "    flags: --local  --allow-shell  --confirm  --tick  --model <id>\n")
    write(2, "           --provider anthropic|openai|debri  --api-base <url>\n")
    write(2, "           --max-iters <n>  --tokens <n>  --every <secs>\n")
    write(2, "    (--provider debri delegates the goal to the devin CLI (SWE-1.x) via\n")
    write(2, "       debri — subscription, no token cost; --model <SWE-1.7|...>,\n")
    write(2, "       --debri-perm auto|dangerous [default dangerous]; needs devin authed\n")
    write(2, "       + debri on PATH on the target; no API key required;\n")
    write(2, "     --confirm parks destructive shell commands for approval;\n")
    write(2, "     --max-denials <n> auto-halts after n denials [default 3];\n")
    write(2, "     --verify checks the goal (independent judge) before accepting finish,\n")
    write(2, "       --max-verify <n> halts after n failed verifies [default 2];\n")
    write(2, "     agent mode reads the API key from ROAM_API_KEY or ANTHROPIC_API_KEY)\n")
    write(2, "  roam status  <host|jobid|last>\n")
    write(2, "  roam attach  <host|jobid|last>\n")
    write(2, "  roam steer   <host|jobid|last> <message>\n")
    write(2, "  roam approve <host|jobid|last>     # allow a parked destructive command\n")
    write(2, "  roam deny    <host|jobid|last>     # refuse it (agent adapts)\n")
    write(2, "  roam stop    <host|jobid|last>\n")
}

func main() {
    a := args()
    if len(a) < 2 { usage()  exit(64) }
    cmd := a[1]
    if cmd == "send"   { cmd_send(a)    return }
    if cmd == "_boot"  { cmd_boot(a)    return }
    if cmd == "_work"  { cmd_work(a)    return }
    if cmd == "status" { cmd_status(a)  return }
    if cmd == "attach" { cmd_attach(a)  return }
    if cmd == "steer"  { cmd_steer(a)   return }
    if cmd == "pause"  { cmd_ctl(a, "pause")   return }
    if cmd == "resume" { cmd_ctl(a, "resume")  return }
    if cmd == "stop"   { cmd_ctl(a, "stop")    return }
    if cmd == "approve" { cmd_ctl(a, "approve")  return }
    if cmd == "deny"    { cmd_ctl(a, "deny")     return }
    if cmd == "help"   { usage()  return }
    write(2, "roam: unknown command: " + cmd + "\n")
    usage()
    exit(64)
}
